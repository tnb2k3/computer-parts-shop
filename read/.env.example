# Environment Variables Example
# Copy this file to .env and fill in your values

# Database
DB_HOST=mysql
DB_NAME=computer_shop
DB_USER=root
DB_PASS=root

# SMTP Settings for Email Verification
# For Gmail: Enable "2-Step Verification" then create an "App Password"
# Go to: Google Account > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=babykonnit7@gmail.com
SMTP_PASSWORD=your-app-password

# Mail From settings (optional, defaults to SMTP_USERNAME)
MAIL_FROM_EMAIL=your-email@gmail.com
MAIL_FROM_NAME=Computer Shop
